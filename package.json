{
  "name": "audio-player-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @audio-player/next dev",
    "dev:all": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3"
  }
}
