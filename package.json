{
  "name": "audio-player",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://code-ninja-web.github.io/audio-player",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --project scripts --noEmit",
    "test": "vitest",
    "test:no-watch": "vitest run",
    "validate": "yarn typecheck && yarn lint && yarn test:no-watch",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src scripts",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix src scripts",
    "format": "prettier --write src/**/*.{ts,tsx,css,md,json}",
    "ingest": "tsc --project scripts && node dist/scripts",
    "prepare": "husky"
  },
  "dependencies": {
    "grommet": "^2.53.0",
    "grommet-icons": "^4.14.0",
    "hls.js": "^1.6.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cheerio": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "yarn lint:fix",
      "git add"
    ]
  }
}
